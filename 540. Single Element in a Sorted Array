class Solution:
    def singleNonDuplicate(self, nums):
        
        left = 0
        right = len(nums) - 1

        while left < right:

            mid = (left + right) // 2

            # Make mid even
            if mid % 2 == 1:
                mid -= 1

            # Pair is correct
            if nums[mid] == nums[mid + 1]:
                left = mid + 2
            else:
                right = mid

        return nums[left]
