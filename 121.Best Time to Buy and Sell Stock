class Solution:
    def maxProfit(self, prices):
        min_price = float('inf')
        max_profit = 0
        
        for price in prices:
            # sabse sasta buy
            if price < min_price:
                min_price = price
            
            # profit calculate
            profit = price - min_price
            
            # max profit update
            if profit > max_profit:
                max_profit = profit
        
        return max_profit

if __name__ == "__main__":
    prices = [7,1,5,3,6,4]
    print(Solution().maxProfit(prices))  # Output: 5
